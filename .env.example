# ====================================================================
#  Настройки подключения к amoCRM
#  Скопируйте этот файл в «.env» и впишите свои данные.
#  Файл .env НЕ попадёт в git (он в .gitignore) — токен останется у вас.
# ====================================================================

# Поддомен вашего amoCRM.
# Если вы заходите по адресу https://myschool.amocrm.ru — здесь пишем "myschool"
AMOCRM_SUBDOMAIN=myschool

# Долгосрочный токен доступа (long-lived access token).
# Где взять: amoCRM → Настройки → Интеграции → Создать интеграцию →
# вкладка «Ключи и доступы» → «Долгосрочный токен».
AMOCRM_ACCESS_TOKEN=вставьте_сюда_ваш_токен

# Домен amoCRM: amocrm.ru (Россия) или amocrm.com / kommo.com (международный).
# Обычно менять не нужно.
AMOCRM_DOMAIN=amocrm.ru

# ------- Настройки самой программы (можно не трогать) -------

# На каком порту открывать веб-панель. Адрес будет http://127.0.0.1:5000
PORT=5000

# Демо-режим: 1 — показать программу на тестовых данных без amoCRM,
# 0 — работать с реальным amoCRM по токену выше.
DEMO_MODE=1
